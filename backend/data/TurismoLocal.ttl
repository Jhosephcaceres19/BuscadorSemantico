###  http://www.semanticweb.org/sarzuri/ontologies/2026/2/turismo-cochabamba#Catedral_Metropolitana
:Catedral_Metropolitana rdf:type owl:NamedIndividual ,
                                 :Atractivo_Cultural_Histórico ;
                        :ofreceEvento :Todos_Santos ;
                        :seLlegaPor :Bus_Turístico_-City_Tour ,
                                    :Taxi_Trufi_Línea_3 ;
                        :Epoca "Colonial" ;
                        :Nivel_Concurrencia "Alto" ;
                        :Nombre "Catedral Metropolitana" ;
