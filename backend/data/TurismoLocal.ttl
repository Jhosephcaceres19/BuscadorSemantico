@base <http://www.semanticweb.org/sarzuri/ontologies/2026/2/turismo-cochabamba#> .

<http://www.semanticweb.org/sarzuri/ontologies/2026/2/turismo-cochabamba> rdf:type owl:Ontology .

#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#string
xsd:string rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://www.semanticweb.org/sarzuri/ontologies/2026/2/turismo-cochabamba#estaCercaDe
:estaCercaDe rdf:type owl:ObjectProperty ;
             rdfs:domain :Entidad_Turistica ;
             rdfs:range :Entidad_Turistica .


###  http://www.semanticweb.org/sarzuri/ontologies/2026/2/turismo-cochabamba#ofreceEvento
:ofreceEvento rdf:type owl:ObjectProperty ;
              rdfs:domain :Entidad_Turistica ;
              rdfs:range :Evento_Turístico .


###  http://www.semanticweb.org/sarzuri/ontologies/2026/2/turismo-cochabamba#ofreceGastronomia
:ofreceGastronomia rdf:type owl:ObjectProperty ;
                   rdfs:domain :Establecimiento_Gastronomico ;
                   rdfs:range :Producto_Alimenticio .


###  http://www.semanticweb.org/sarzuri/ontologies/2026/2/turismo-cochabamba#ofreceHospedaje
:ofreceHospedaje rdf:type owl:ObjectProperty ;
                 rdfs:domain :Servicio_Turistico ;
                 rdfs:range :Hospedaje .


###  http://www.semanticweb.org/sarzuri/ontologies/2026/2/turismo-cochabamba#seLlegaPor
:seLlegaPor rdf:type owl:ObjectProperty ;
            rdfs:domain :Atractivo_Turistico ;
            rdfs:range :Transporte .


###  http://www.semanticweb.org/sarzuri/ontologies/2026/2/turismo-cochabamba#seRealizaEn
:seRealizaEn rdf:type owl:ObjectProperty ;
             rdfs:domain :Evento_Turístico ;
             rdfs:range :Atractivo_Turistico .


###  http://www.semanticweb.org/sarzuri/ontologies/2026/2/turismo-cochabamba#tieneAtractivo
:tieneAtractivo rdf:type owl:ObjectProperty ;
                rdfs:domain :Entidad_Turistica ;
                rdfs:range :Atractivo_Turistico .


###  http://www.semanticweb.org/sarzuri/ontologies/2026/2/turismo-cochabamba#tieneEstablecimiento
:tieneEstablecimiento rdf:type owl:ObjectProperty ;
                      rdfs:domain :Atractivo_Turistico ;
                      rdfs:range :Establecimiento_Gastronomico .


###  http://www.semanticweb.org/sarzuri/ontologies/2026/2/turismo-cochabamba#ubicadoEn
:ubicadoEn rdf:type owl:ObjectProperty ;
           rdfs:domain :Entidad_Turistica ;
           rdfs:range :Entidad_Turistica .


