                        :Tiene_Descuento "true"^^xsd:boolean ;
                        :Tipo_Patrimonio "Arquitectura Religiosa" .


###  http://www.semanticweb.org/sarzuri/ontologies/2026/2/turismo-cochabamba#Cañadón_de_la_Angostura
:Cañadón_de_la_Angostura rdf:type owl:NamedIndividual ,
                                  :Atractivo_Natural ;
                         :Descripcion "Formaciones geológicas estrechas donde el río serpentea entre paredes de roca, ideal para fotografía de aventura." ;
