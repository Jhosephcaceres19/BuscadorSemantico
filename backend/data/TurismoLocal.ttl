                        :Gratuito "false"^^xsd:boolean ;
                        :Nombre "Centro \"Simón I. Patiño\"" ;
                        :Requiere_Reserva "true"^^xsd:boolean ;
                        :Tipo_Atractivo "Natural / Paisajístico / Ecológico" ;
                        :Ubicacion "Cercado" .


