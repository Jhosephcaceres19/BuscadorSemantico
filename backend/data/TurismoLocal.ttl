#################################################################
#    Classes
#################################################################

###  http://www.semanticweb.org/sarzuri/ontologies/2026/2/turismo-cochabamba#Atractivo_Arqueológico
:Atractivo_Arqueológico rdf:type owl:Class ;
                        rdfs:subClassOf :Atractivo_Turistico ;
                        owl:disjointWith :Atractivo_Cultural_Histórico ,
                                         :Atractivo_Natural ,
                                         :Atractivo_Recreativo .


###  http://www.semanticweb.org/sarzuri/ontologies/2026/2/turismo-cochabamba#Atractivo_Cultural_Histórico
:Atractivo_Cultural_Histórico rdf:type owl:Class ;
                              rdfs:subClassOf :Atractivo_Turistico ;
                              owl:disjointWith :Atractivo_Natural ,
                                               :Atractivo_Recreativo .


###  http://www.semanticweb.org/sarzuri/ontologies/2026/2/turismo-cochabamba#Atractivo_Natural
:Atractivo_Natural rdf:type owl:Class ;
                   rdfs:subClassOf :Atractivo_Turistico ;
                   owl:disjointWith :Atractivo_Recreativo .


###  http://www.semanticweb.org/sarzuri/ontologies/2026/2/turismo-cochabamba#Atractivo_Recreativo
:Atractivo_Recreativo rdf:type owl:Class ;
                      rdfs:subClassOf :Atractivo_Turistico .


###  http://www.semanticweb.org/sarzuri/ontologies/2026/2/turismo-cochabamba#Atractivo_Turistico
:Atractivo_Turistico rdf:type owl:Class ;
                     rdfs:subClassOf :Entidad_Turistica ;
                     owl:disjointWith :Servicio_Turistico .


###  http://www.semanticweb.org/sarzuri/ontologies/2026/2/turismo-cochabamba#Entidad_Turistica
:Entidad_Turistica rdf:type owl:Class .


###  http://www.semanticweb.org/sarzuri/ontologies/2026/2/turismo-cochabamba#Establecimiento_Gastronomico
:Establecimiento_Gastronomico rdf:type owl:Class ;
                              rdfs:subClassOf :Gastronomía ;
                              owl:disjointWith :Producto_Alimenticio .


###  http://www.semanticweb.org/sarzuri/ontologies/2026/2/turismo-cochabamba#Evento_Turístico
:Evento_Turístico rdf:type owl:Class ;
                  rdfs:subClassOf :Servicio_Turistico ;
                  owl:disjointWith :Gastronomía ,
                                   :Hospedaje ,
                                   :Transporte .


###  http://www.semanticweb.org/sarzuri/ontologies/2026/2/turismo-cochabamba#Gastronomía
:Gastronomía rdf:type owl:Class ;
             rdfs:subClassOf :Servicio_Turistico ;
             owl:disjointWith :Hospedaje ,
                              :Transporte .


###  http://www.semanticweb.org/sarzuri/ontologies/2026/2/turismo-cochabamba#Hospedaje
:Hospedaje rdf:type owl:Class ;
           rdfs:subClassOf :Servicio_Turistico ;
           owl:disjointWith :Transporte .


###  http://www.semanticweb.org/sarzuri/ontologies/2026/2/turismo-cochabamba#Producto_Alimenticio
:Producto_Alimenticio rdf:type owl:Class ;
                      rdfs:subClassOf :Gastronomía .


###  http://www.semanticweb.org/sarzuri/ontologies/2026/2/turismo-cochabamba#Servicio_Turistico
:Servicio_Turistico rdf:type owl:Class ;
                    rdfs:subClassOf :Entidad_Turistica .


###  http://www.semanticweb.org/sarzuri/ontologies/2026/2/turismo-cochabamba#Transporte
:Transporte rdf:type owl:Class ;
            rdfs:subClassOf :Servicio_Turistico .


#################################################################
#    Individuals
#################################################################

###  http://www.semanticweb.org/sarzuri/ontologies/2026/2/turismo-cochabamba#Aguas_Termales_de_Liriuni
:Aguas_Termales_de_Liriuni rdf:type owl:NamedIndividual ,
                                    :Atractivo_Natural ;
                           :Descripcion "Pozas naturales de aguas medicinales que brotan de la montaña con una vista privilegiada del valle ." ;
                           :Horario_Apertura "07:00" ;
                           :Horario_Cierra "16:00" ;
                           :Nombre "Aguas Termales de Liriuni" ;
                           :Ubicacion "Quillacollo" .


###  http://www.semanticweb.org/sarzuri/ontologies/2026/2/turismo-cochabamba#Alojamiento_Rural
:Alojamiento_Rural rdf:type owl:NamedIndividual ,
                            :Hospedaje ;
                   :Disponible "true"^^xsd:boolean ;
                   :Incluye_Servicios "Áreas Verdes, Camping" ;
                   :Precio_Dia "180.0"^^xsd:float ;
                   :Precio_Noche "120.0"^^xsd:float ;
                   :Tipo_Hospedaje "Alojamiento Rural" .


###  http://www.semanticweb.org/sarzuri/ontologies/2026/2/turismo-cochabamba#Bosque_de_los_PInos
:Bosque_de_los_PInos rdf:type owl:NamedIndividual ,
                              :Atractivo_Natural ;
                     :Descripcion "Un extenso sendero de pinos antiguos que crean un microclima místico en uno de los pueblos más coloniales de Bolivia." ;
                     :Horario_Apertura "06:00" ;
                     :Horario_Cierra "18:00" ;
                     :Nombre "Bosque de los pinos" ;
                     :Ubicacion "Totora" .


###  http://www.semanticweb.org/sarzuri/ontologies/2026/2/turismo-cochabamba#Buffet_Hotel_Cochabamba
:Buffet_Hotel_Cochabamba rdf:type owl:NamedIndividual ,
                                  :Establecimiento_Gastronomico ;
                         :Horario_Atencion "07:00 - 22:00" ;
                         :Servicios "Piscina, Buffet internacional" ;
                         :Tipo_Establecimiento "Restaurante de Lujo" ;
                         :Ubicacion "Recoleta" .


###  http://www.semanticweb.org/sarzuri/ontologies/2026/2/turismo-cochabamba#Bus_Interdepartamental
:Bus_Interdepartamental rdf:type owl:NamedIndividual ,
                                 :Transporte ;
                        :Capacidad 45 ;
                        :Costo_Aproximado "40.0"^^xsd:float ;
                        :Horario_Servicio "07:00 - 23:00" ;
                        :Ruta "Terminal - Santa Cruz/La Paz" ;
                        :Tipo_Transporte "Bus Interdepartamental" .


###  http://www.semanticweb.org/sarzuri/ontologies/2026/2/turismo-cochabamba#Bus_Turístico_-City_Tour
:Bus_Turístico_-City_Tour rdf:type owl:NamedIndividual ,
                                   :Transporte ;
                          :Capacidad 30 ;
                          :Costo_Aproximado "25.0"^^xsd:float ;
                          :Horario_Servicio "Fines de semana" ;
                          :Ruta "Circuito Histórico / Miradores" ;
                          :Tipo_Transporte "Bus Turístico (City Tour)" .


###  http://www.semanticweb.org/sarzuri/ontologies/2026/2/turismo-cochabamba#Casona_Santiváñez
:Casona_Santiváñez rdf:type owl:NamedIndividual ,
                            :Atractivo_Cultural_Histórico ;
                   :Epoca "Colonial/Repub." ;
                   :Nombre "Casona Santiváñez" ;
                   :Patrimonio_Nacional "true"^^xsd:boolean ;
                   :Tipo_Patrimonio "Arquitectura Civil" .


###  http://www.semanticweb.org/sarzuri/ontologies/2026/2/turismo-cochabamba#Casona_de_Mayorazgo
:Casona_de_Mayorazgo rdf:type owl:NamedIndividual ,
